# ==========================================
# MASTER ROOT GITIGNORE
# ==========================================

# Ignore IDE settings & OS Garbage (Applies everywhere)
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db

# ------------------------------------------
# 1. NOTIFICATION SERVICE (Node.js)
# ------------------------------------------
Notification-Service/node_modules/
Notification-Service/npm-debug.log*
Notification-Service/yarn-debug.log*
Notification-Service/yarn-error.log*
Notification-Service/.env

# ------------------------------------------
# 2. JAVA SPRING BOOT SERVICES
# (Applies to User, Task, Gateway, & Registry)
# ------------------------------------------

# Target / Build directories (Where compiled Java lives)
**/target/
**/build/
**/out/

# Log files generated by Spring Boot
*.log

# Crash logs
hs_err_pid*

# Help folders created by Spring Initializr
.mvn/wrapper/
mvnw
mvnw.cmd
.help/

# Local Environment/Config files for Java
*/src/main/resources/application-secret.properties
*/src/main/resources/application-secret.yml
*/src/.gitignore
*/.gitignore